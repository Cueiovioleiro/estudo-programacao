<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landing Page - Nome do Projeto</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    
    <!-- Hero Section (parte de cima) -->
    <header>
        <h1>Título Chamativo Aqui</h1>
        <p>Subtítulo explicando o benefício principal</p>
        <button class="btn-primary">Quero saber mais</button>
    </header>

    <!-- Seção de Benefícios -->
    <section id="beneficios">
        <h2>Por que escolher isso?</h2>
        <div class="cards">
            <div class="card">Benefício 1</div>
            <div class="card">Benefício 2</div>
            <div class="card">Benefício 3</div>
        </div>
    </section>

    <!-- Call to Action -->
    <section id="cta">
        <h2>Pronto pra começar?</h2>
        <button class="btn-primary">Inscreva-se agora</button>
    </section>

    <footer>
        <p>Feito para portfólio • Estudos de HTML + CSS</p>
    </footer>

</body>
</html>
